# ---------- OLLAMA / LLM SETTINGS ----------
# Where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Which model to use (must exist in `ollama list`)
# e.g. mistral:latest, llama3.2:1b, phi3:mini
OLLAMA_MODEL=llama3.2:1b

# Max tokens to generate in the answer (smaller = faster)
OLLAMA_NUM_PREDICT=160

# How long to keep model in memory after use
OLLAMA_KEEP_ALIVE=10m


# Device SETTINGS
# Which device to run the model on (cpu, gpu, mps)
OLLAMA_DEVICE=cpu   



# ---------- EMBEDDING SETTINGS ----------
# Which sentence transformer model to use for embeddings
SENTENCE_TRANSFORMER=all-MiniLM-L6-v2


# ---------- CHUNKING / RETRIEVAL SETTINGS ----------
# Character length of each text chunk
CHUNK_SIZE=1000

# Overlap between chunks in characters
CHUNK_OVERLAP=200

# How many chunks to retrieve from vector DB per question
TOP_K=4


# ---------- VECTOR DB SETTINGS ----------
# Where Chroma will store its data
CHROMA_DB_DIR=chroma_db

# Disable parallelism for tokenizers to avoid warnings
TOKENIZERS_PARALLELISM=false